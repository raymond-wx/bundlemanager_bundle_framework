import("//build/test.gni")
import("../../../../../appexecfwk.gni")
import("../../../../../services/bundlemgr/appexecfwk_bundlemgr.gni")
module_output_path = "bundle_framework/bundle_framework"

ohos_unittest("BmsModuleProfileTest") {
  sanitize = {
    cfi = true
    cfi_cross_dso = true
    debug = false
  }
  module_out_path = module_output_path
  include_dirs = [
    "${bundle_framework_path}interfaces/inner_api/appexecfwk_core/include/bundlemgr",
    "${services_path}/bundlemgr/include",
  ]
  sources = [
    "bms_module_profile_test.cpp",
    "${services_path}/bundlemgr/src/inner_bundle_info.cpp",
    "${services_path}/bundlemgr/src/inner_bundle_user_info.cpp",
  ]

  cflags = []
  if (target_cpu == "arm") {
    cflags += [ "-DBINDER_IPC_32BIT" ]
  }
  deps = [
    "${base_path}:appexecfwk_base",
    "${common_path}:libappexecfwk_common",
    "${core_path}:appexecfwk_core",
    "${services_path}/bundlemgr:bundle_parser",
  ]

  external_deps = [
    "ability_base:want",
    "ability_runtime:app_manager",
    "access_token:libtokenid_sdk",
    "appverify:libhapverify",
    "c_utils:utils",
    "hilog:libhilog",
    "init:libbegetutil",
    "ipc:ipc_core",
    "json:nlohmann_json_static",
    "samgr:samgr_proxy",
    "zlib:shared_libz",
  ]
  external_deps += bundle_install_external_deps
}

group("unittest") {
  testonly = true

  deps = [ ":BmsModuleProfileTest" ]
}