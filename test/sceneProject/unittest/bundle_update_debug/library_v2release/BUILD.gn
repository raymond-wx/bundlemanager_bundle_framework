import("//build/ohos.gni")
import("../../../../../appexecfwk.gni")

ohos_hap("library_v2release") {
  hap_profile = "library/src/main/module.json"
  hap_name = "library_v2release"
  subsystem_name = "bundlemanager"
  final_hap_path = "$root_out_dir/tests/unittest/bundle_framework/bundlemgrservice/resource/bundle_update_debug/${hap_name}.hap"
  testonly = true
  deps = [
    ":mydemo_js_assets",
    ":mydemo_resources",
  ]
  js_build_mode = "release"
  certificate_profile = "${bundle_framework_path}/test/sceneProject/signature/com.test.debug.update.p7b"
}

ohos_app_scope("mydemo_app_profile") {
  app_profile = "AppScope/app.json"
  sources = [ "AppScope/resources" ]
}

ohos_js_assets("mydemo_js_assets") {
  source_dir = "library/src/main/ets"
}

ohos_resources("mydemo_resources") {
  sources = [ "library/src/main/resources" ]
  deps = [ ":mydemo_app_profile" ]
  hap_profile = "library/src/main/module.json"
}
